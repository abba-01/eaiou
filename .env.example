# eaiou — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=eaiou
DB_USER=eaiou
DB_PASS=changeme

# ── Admin Auth (Phase 1 — single admin, no users table) ───────────────────
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── Session ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme

# ── Environment ───────────────────────────────────────────────────────────
# development | production
ENVIRONMENT=development
